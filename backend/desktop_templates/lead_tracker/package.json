{
  "name": "lead-tracker",
  "version": "1.0.0",
  "description": "{{APP_TITLE}} — {{CLIENT_NAME}}",
  "main": "main.js",
  "author": "CapCore",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "pro.capcore.lead-tracker",
    "productName": "{{APP_TITLE}}",
    "directories": {
      "output": "dist"
    },
    "files": ["main.js", "index.html", "styles.css"],
    "win": {
      "target": ["portable"],
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "{{APP_TITLE}}.exe"
    }
  }
}
