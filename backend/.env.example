# CyberForge backend — variables d'environnement (copier vers backend/.env)
ENVIRONMENT=development

# Mistral AI — briefs / analyses (volume économique, invisible client)
MISTRAL_API_KEY=your_mistral_key_here

# Google Gemini Flash — couche quasi-gratuite (fallback brief / analyse)
GEMINI_API_KEY=your_gemini_key_here

# Cloudflare Pages + DNS sous-domaines capcore.pro
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_ZONE_ID=your_zone_id_here
