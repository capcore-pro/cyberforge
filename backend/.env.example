# CyberForge backend — variables d'environnement (copier vers backend/.env)
ENVIRONMENT=development

# Mistral AI — briefs / analyses (volume économique, invisible client)
MISTRAL_API_KEY=your_mistral_key_here

# Google Gemini Flash — couche quasi-gratuite (fallback brief / analyse)
GEMINI_API_KEY=your_gemini_key_here

# FFmpeg — assemblage vidéo CyberForge (Video Builder, scripts musique)
# Chemins absolus recommandés sous Windows ; sinon laisser vide et s'appuyer sur le PATH
FFMPEG_PATH=C:\ffmpeg\ffmpeg-master-latest-win64-gpl-shared\bin\ffmpeg.exe
FFPROBE_PATH=C:\ffmpeg\ffmpeg-master-latest-win64-gpl-shared\bin\ffprobe.exe

# Cloudflare Pages + DNS sous-domaines capcore.pro
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_ZONE_ID=your_zone_id_here

# OpenHands Cloud — analyse & correction (pipeline + mode Debug)
# À dupliquer dans Railway → Variables d'environnement du service backend
OPENHANDS_API_KEY=your_key_here
# OPENHANDS_API_URL=https://app.all-hands.dev/api/v1
# OPENHANDS_ENABLED=true
