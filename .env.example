# CyberForge — variables d'environnement (copier vers .env à la racine)
# Ne jamais committer le fichier .env. Les clés API restent hors du code source.

# --- Application ---
APP_ENV=development
APP_NAME=CyberForge
APP_DEBUG=

# --- Backend FastAPI ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8001
BACKEND_URL=http://127.0.0.1:8001

# --- Frontend / Electron ---
VITE_API_BASE_URL=http://127.0.0.1:8001

# --- Base de données ---
DATABASE_URL=

# --- Fournisseurs IA (clés via variables d'environnement uniquement) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=

# --- Bolt.new (génération de code) ---
# Clé API Bolt.new / StackBlitz si disponible ; sinon repli OpenAI/Anthropic (BOLT_MODEL)
BOLT_API_KEY=
BOLT_API_BASE_URL=
BOLT_MODEL=gpt-4o-mini

# --- Sécurité ---
SECRET_KEY=
CORS_ORIGINS=
