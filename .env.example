# CyberForge — variables d'environnement (copier vers .env à la racine)
# Ne jamais committer le fichier .env. Les clés API restent hors du code source.

# --- Application ---
APP_ENV=development
APP_NAME=CyberForge
APP_DEBUG=

# --- Backend FastAPI ---
BACKEND_HOST=
BACKEND_PORT=
BACKEND_URL=

# --- Frontend / Electron ---
VITE_API_BASE_URL=

# --- Base de données ---
DATABASE_URL=

# --- Fournisseurs IA (clés via variables d'environnement uniquement) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=

# --- Sécurité ---
SECRET_KEY=
CORS_ORIGINS=
