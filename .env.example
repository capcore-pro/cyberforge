# CyberForge — variables d'environnement (copier vers backend/.env)
# Ne jamais committer les fichiers .env. Les clés API restent hors du code source.

# --- Application ---
APP_ENV=development
APP_NAME=CyberForge
APP_DEBUG=

# --- Backend FastAPI ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8001
BACKEND_URL=http://127.0.0.1:8001

# --- Frontend / Electron ---
VITE_API_BASE_URL=http://127.0.0.1:8001

# --- Base de données ---
DATABASE_URL=

# --- Supabase (historique projets / générations) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
# Alias accepté : SUPABASE_SERVICE_ROLE_KEY (clé service_role du dashboard Supabase)

# --- Fournisseurs IA (de préférence via Paramètres → coffre chiffré local) ---
# Ne pas mettre les clés LLM ici en production. Fallback .env possible en dev.
OPENAI_API_KEY=
OLLAMA_BASE_URL=

# --- CoreMindAI : routage par coût (DeepSeek → Gemini Flash → Haiku → Sonnet) ---
# Enregistrer via l'écran Paramètres (POST /api/secrets/save) plutôt que ce fichier.
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

COREMIND_DEEPSEEK_MODEL=deepseek-chat
COREMIND_GEMINI_MODEL=gemini-2.0-flash
COREMIND_HAIKU_MODEL=claude-3-5-haiku-20241022
COREMIND_SONNET_MODEL=claude-sonnet-4-20250514

# --- Sécurité ---
SECRET_KEY=
CORS_ORIGINS=
