# CyberForge — variables d'environnement (copier vers backend/.env)
# Ne jamais committer les fichiers .env. Les clés API restent hors du code source.

# --- Application ---
APP_ENV=development
APP_NAME=CyberForge
APP_DEBUG=

# --- Backend FastAPI ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8002
BACKEND_URL=http://127.0.0.1:8002
# URL API injectée dans les démos Cloudflare (formulaire « Contacter CapCore »)
DEMO_API_BASE_URL=https://cyberforge-backend-production.up.railway.app

# --- Frontend / Electron ---
VITE_API_BASE_URL=http://127.0.0.1:8002
# URL publique pour les liens démo client (/demo/{token})
FRONTEND_PUBLIC_URL=http://localhost:5173

# --- Base de données ---
DATABASE_URL=

# --- Supabase (historique projets / générations) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
# Alias accepté : SUPABASE_SERVICE_ROLE_KEY (clé service_role du dashboard Supabase)

# --- Médiathèque — stockage local + Cloudflare R2 (backend/.env + Railway) ---
# Racine locale (défaut : <repo>/media/) — ex. C:/Users/mathi/cyberforge/media/
# MEDIA_ROOT=
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET=cyberforge-media
# URL publique du bucket (domaine R2 custom ou *.r2.dev)
# CLOUDFLARE_R2_PUBLIC_BASE_URL=

# --- Cloudflare Pages (démos client) — backend/.env uniquement ---
# Token API (Custom) : Account → Cloudflare Pages → Edit
#   (équivalent dashboard « Pages Write »). Aucune permission supplémentaire
#   pour upsert-hashes : cet appel utilise le JWT renvoyé par upload-token.
CLOUDFLARE_ACCOUNT_ID=
# Token API (Pages Write) — déploiement projet fixe cyberforge-demos
CLOUDFLARE_API_TOKEN=

# --- Fournisseurs IA (de préférence via Paramètres → coffre chiffré local) ---
# Ne pas mettre les clés LLM ici en production. Fallback .env possible en dev.
OPENAI_API_KEY=
OLLAMA_BASE_URL=

# --- CoreMindAI : routage par coût (DeepSeek → Gemini Flash → Haiku → Sonnet) ---
# Enregistrer via l'écran Paramètres (POST /api/secrets/save) plutôt que ce fichier.
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

COREMIND_DEEPSEEK_MODEL=deepseek-chat
COREMIND_GEMINI_MODEL=gemini-2.0-flash
COREMIND_HAIKU_MODEL=claude-3-5-haiku-20241022
COREMIND_SONNET_MODEL=claude-sonnet-4-20250514

# --- BuilderAI : v0 (UI React) + DeepSeek (code complexe ; fallback CoreMindAI) ---
V0_API_KEY=
# V0_API_BASE_URL=https://api.v0.dev/v1
# V0_MODEL=v0-1.5-md

# --- VisionUI : screenshot HTML (fallback rendu local si absent) ---
REPLICATE_API_KEY=
# REPLICATE_HTML_MODEL=intelligent-utilities/html-to-image

# --- ExportAI : Cloudflare (démos), Railway (backend), GitHub (sources) ---
RAILWAY_API_KEY=
GITHUB_TOKEN=
# GITHUB_REPO=owner/repo
# Dépôt dédié vitrines Next.js (une branche = un site, pour Vercel)
VITRINES_GITHUB_REPO=mathiasgibiard-dotcom/vitrines
# Token https://vercel.com/account/tokens (setup script vercel_setup_vitrines.py)
VERCEL_TOKEN=

# --- Vitrine Next.js : images Unsplash (Phase 4.2c) — backend/.env ---
# Créer une app sur https://unsplash.com/developers puis Access Key
UNSPLASH_ACCESS_KEY=
# UNSPLASH_HTTP_TIMEOUT_SECONDS=12

# --- Documents juridiques (devis, factures, CGV) — ReportLab ---
# LEGAL_DOCUMENTS_ROOT=C:/Users/mathi/cyberforge/documents/
# MAT_SIRET=
# MAT_LEGAL_NAME=Mathias Gibiard
# MAT_LEGAL_ACTIVITY=CapCore — CyberForge / Cap Copy
# MAT_LEGAL_EMAIL=capcore.pro@gmail.com

# --- Notifications CapCore (formulaire démo → email Mat, API Brevo) ---
CAPCORE_NOTIFY_EMAIL=capcore.pro@gmail.com
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@capcore.pro
BREVO_SENDER_NAME=CapCore

# --- Sécurité ---
SECRET_KEY=
CORS_ORIGINS=
