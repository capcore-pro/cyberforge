# CyberForge — variables d'environnement (copier vers .env à la racine)
# Ne jamais committer le fichier .env. Les clés API restent hors du code source.

# --- Application ---
APP_ENV=development
APP_NAME=CyberForge
APP_DEBUG=

# --- Backend FastAPI ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8001
BACKEND_URL=http://127.0.0.1:8001

# --- Frontend / Electron ---
VITE_API_BASE_URL=http://127.0.0.1:8001

# --- Base de données ---
DATABASE_URL=

# --- Fournisseurs IA (clés via variables d'environnement uniquement) ---
OPENAI_API_KEY=
OLLAMA_BASE_URL=

# --- CoreMindAI / Claude (génération de code) ---
ANTHROPIC_API_KEY=
COREMIND_CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Sécurité ---
SECRET_KEY=
CORS_ORIGINS=
