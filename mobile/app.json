{
  "expo": {
    "name": "CyberForge",
    "slug": "cyberforge-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cyberforge",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d0d"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0d0d0d"
      },
      "package": "pro.capcore.cyberforge"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#c9a84c"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4805e9b5-8556-4f95-9a50-4d6c9c1be06e"
      }
    },
    "owner": "cyberforge"
  }
}
